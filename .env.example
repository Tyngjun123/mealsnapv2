# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here   # openssl rand -base64 32

# ─── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ─── Vercel Postgres ──────────────────────────────────────────
# Auto-filled by Vercel after connecting a Postgres store in your project
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=...
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...

# ─── Vercel Blob ──────────────────────────────────────────────
# Auto-filled by Vercel after connecting a Blob store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# ─── AI Provider ─────────────────────────────────────────────
# Choose one: claude | gemini | openai  (default: claude)
AI_PROVIDER=gemini

# Option A — Google Gemini Flash (FREE: 1500 req/day)
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza-xxxx

# Option B — Anthropic Claude (Best accuracy, ~$52/100 users/mo)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx

# Option C — OpenAI GPT-4o mini (Cheapest paid, ~$14/100 users/mo)
# Get from: https://platform.openai.com
OPENAI_API_KEY=sk-xxxx

# ─── Migration ────────────────────────────────────────────────
# Any random string — used to protect POST /api/migrate
MIGRATION_SECRET=change-me-to-something-random
